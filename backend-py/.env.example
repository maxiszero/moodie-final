PORT=8000
MONGODB_URI=mongodb://127.0.0.1:27017/moodie
# Optional. If omitted and MONGODB_URI has no database path, MongoDB/Mongoose default to "test".
# MONGODB_DB_NAME=moodie
JWT_SECRET=change_me
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional AI providers
AI_API_KEYS=
AI_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_WEEKLY_PRIMARY=auto

# Telegram Mini App — must match the bot that opens this web app (for /api/auth/telegram/link)
TELEGRAM_BOT_TOKEN=
# HTTPS Mini App URL (inline «Open» button, menu button via scripts/setupTelegramBot.mjs)
TELEGRAM_WEB_APP_URL=https://example.com
TELEGRAM_BOT_SHORT_NAME=Moodie
# Hour (0–23 UTC) for daily /notify reminders; API process runs the scheduler (single worker recommended)
TELEGRAM_DAILY_NOTIFY_UTC_HOUR=8
# true = getUpdates long polling in this process (disable if you run multiple API workers and use webhook instead)
TELEGRAM_ENABLE_POLLING=true
